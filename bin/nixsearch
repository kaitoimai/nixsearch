#!/usr/bin/env bash
# nixsearch — is this tool packaged in nixpkgs, and does it build for
# aarch64-darwin (Apple Silicon)? Usage: nixsearch <name>
#
# Relies on the ambient `nix` CLI and on `jq` from the packaged runtime inputs.

usage() {
  echo "Usage: nixsearch <name>"
  echo "  Search nixpkgs for <name>; report availability + aarch64-darwin support."
}

if [ "$#" -eq 1 ] && { [ "$1" = "-h" ] || [ "$1" = "--help" ]; }; then
  usage
  exit 0
fi

if [ "$#" -ne 1 ] || [ -z "$1" ]; then
  usage >&2
  exit 2
fi

query="$1"

# Colours only when stdout is a terminal.
if [ -t 1 ]; then
  b=$'\033[1m'; d=$'\033[2m'; g=$'\033[32m'; r=$'\033[31m'; y=$'\033[33m'; c=$'\033[36m'; z=$'\033[0m'
else
  b=''; d=''; g=''; r=''; y=''; c=''; z=''
fi
ok="${g}✓${z}"
no="${r}✗${z}"

# Function applied to each package to pull the meta fields we care about.
apply='
  p:
  let
    m = p.meta or {};
    plats = m.platforms or [];
    lic = m.license or null;
    pick = x: x.shortName or (x.spdxId or (x.fullName or "?"));
    licStr =
      if lic == null then null
      else if builtins.isList lic then builtins.concatStringsSep ", " (builtins.map pick lic)
      else if builtins.isAttrs lic then pick lic
      else builtins.toString lic;
  in {
    available = m.available or true;
    darwin = builtins.elem "aarch64-darwin" plats;
    mainProgram = m.mainProgram or null;
    broken = m.broken or false;
    unfree = m.unfree or false;
    homepage = m.homepage or null;
    license = licStr;
  }
'

print_detail() {
  attr="$1"
  ver="$2"
  json=$(nix eval --json "nixpkgs#$attr" --apply "$apply" 2>/dev/null) || json='{}'

  avail=$(printf '%s' "$json" | jq -r '.available // false')
  darwin=$(printf '%s' "$json" | jq -r '.darwin // false')
  main=$(printf '%s' "$json" | jq -r '.mainProgram // "—"')
  broken=$(printf '%s' "$json" | jq -r '.broken // false')
  unfree=$(printf '%s' "$json" | jq -r '.unfree // false')
  home=$(printf '%s' "$json" | jq -r '.homepage // "—"')
  lic=$(printf '%s' "$json" | jq -r '.license // "—"')

  printf '\n%s%s%s %s(%s)%s\n' "$b" "$attr" "$z" "$d" "$ver" "$z"

  if [ "$avail" = "true" ]; then
    printf '  installable here   %s yes\n' "$ok"
  else
    printf '  installable here   %s no (not for this system)\n' "$no"
  fi

  if [ "$darwin" = "true" ]; then
    printf '  aarch64-darwin     %s in meta.platforms\n' "$ok"
  else
    printf '  aarch64-darwin     %s not in meta.platforms\n' "$no"
  fi

  if [ "$broken" = "true" ]; then
    printf '  %s⚠ marked broken%s\n' "$y" "$z"
  fi
  if [ "$unfree" = "true" ]; then
    printf '  %s⚠ unfree — needs nixpkgs.config.allowUnfree%s\n' "$y" "$z"
  fi

  printf '  main binary        %s\n' "$main"
  printf '  license            %s\n' "$lic"
  printf '  homepage           %s\n' "$home"
  printf '  add to config      %s%s%s  %s← home.packages in modules/home/default.nix%s\n' "$c" "$attr" "$z" "$d" "$z"
}

printf '%ssearching nixpkgs for "%s"…%s\n' "$d" "$query" "$z" >&2

results=$(nix search nixpkgs "$query" --json 2>/dev/null) || results=''
[ -n "$results" ] || results='{}'

count=$(printf '%s' "$results" | jq 'length')

if [ "$count" -eq 0 ]; then
  printf '%s no nixpkgs package matches %s"%s"%s\n' "$no" "$b" "$query" "$z"
  printf '\n%stry instead:%s\n' "$d" "$z"
  printf '  • by binary name : %snix-locate bin/%s%s  %s(needs nix-index)%s\n' "$c" "$query" "$z" "$d" "$z"
  printf '  • web UI         : %shttps://search.nixos.org/packages?query=%s%s\n' "$c" "$query" "$z"
  printf '  • not in nixpkgs : write your own derivation in packages/\n'
  exit 1
fi

printf '%s %s%s%s match(es)\n\n%sMatches:%s\n' "$ok" "$b" "$count" "$z" "$b" "$z"

entries=$(printf '%s' "$results" | jq -r 'to_entries[] | [.key, .value.version, (.value.description // "")] | @tsv')

to_detail=()
attr=''
ver=''
while IFS=$'\t' read -r key ver desc; do
  attr=${key#legacyPackages.*.}
  printf '  %s%-28s%s %s%s%s  %s\n' "$c" "$attr" "$z" "$d" "$ver" "$z" "$desc"
  base=${attr##*.}
  if [ "$base" = "$query" ] || [ "$attr" = "$query" ]; then
    to_detail+=("$attr"$'\t'"$ver")
  fi
done <<<"$entries"

# Exactly one hit and no name match: detail it anyway (attr/ver survive the loop).
if [ "${#to_detail[@]}" -eq 0 ] && [ "$count" -eq 1 ]; then
  to_detail+=("$attr"$'\t'"$ver")
fi

if [ "${#to_detail[@]}" -gt 0 ]; then
  for item in "${to_detail[@]}"; do
    print_detail "${item%%$'\t'*}" "${item#*$'\t'}"
  done
else
  printf '\n%stip:%s run %snixsearch <exact-attr>%s for full details on one package.\n' "$d" "$z" "$c" "$z"
fi

printf '\n%ssource: nixpkgs flake registry (unstable) — versions may differ slightly from your flake.lock%s\n' "$d" "$z"
